# ─────────────────────────────────────────────────────────────
# .gitignore — GitHub에 올라가면 안 되는 파일들
# ─────────────────────────────────────────────────────────────

# 로컬 서버 전체 (DB 자격증명 포함) — 절대 커밋 금지
server/

# 환경변수 파일
.env
.env.*
*.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
