# ─────────────────────────────────────────────────────────────
# .gitignore — GitHub에 올라가면 안 되는 파일들
# ─────────────────────────────────────────────────────────────

# 환경변수 파일
.env
.env.*
*.env

# 서버 실행파일 및 로그
server/ngrok.exe
server/cloudflared.exe
server/cloudflared_url.log
server/warm_beta_cache.log
server/logs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# RV Position 사용자 데이터 (private)
server/app/data/rv_positions.json
server/app/data/*.json

# Claude Code internal
.claude/

# 로컬 렌더링 산출물 (MD 원본만 추적)
*.pdf

# 루트 스크래치 (ripgrep 등 임시 산출 — publish="." 공개서빙 방지)
/_rg.json
/_*.json
