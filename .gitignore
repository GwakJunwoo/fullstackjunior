# ─────────────────────────────────────────────────────────────
# .gitignore — GitHub에 올라가면 안 되는 파일들
# ─────────────────────────────────────────────────────────────

# 환경변수 파일
.env
.env.*
*.env

# 서버 실행파일 및 로그
server/ngrok.exe
server/logs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
